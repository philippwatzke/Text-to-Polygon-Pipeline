# WCS — primary data acquisition path (Spec §5.1, post-2026-04-28 revision).
# All pipeline input goes through WCS so we get raw, unrendered coverage data.
DOP_SOURCE=wcs
WCS_URL=https://geoservices.bayern.de/pro/wcs/dop/v1/wcs_inspire_dop20
WCS_VERSION=2.0.1
WCS_COVERAGE_ID=OI.OrthoimageCoverage
WCS_FORMAT=image/tiff
WCS_CRS=EPSG:25832
WCS_MAX_PIXELS=6000
WCS_USERNAME=
WCS_PASSWORD=

# WMS — UI-only basemap for the Leaflet review map. Not used for any
# pipeline input. Public, no auth.
WMS_URL=https://geoservices.bayern.de/od/wms/dop/v1/dop20
WMS_LAYER=by_dop20c
WMS_VERSION=1.1.1
WMS_FORMAT=image/png
WMS_CRS=EPSG:25832

# SAM 3.1 — Hugging Face id by default; override with a local snapshot dir.
SAM3_MODEL_ID=facebook/sam3
SAM3_CHECKPOINT=models/sam3.1_hiera_large.pt
SAM3_LOCAL_FILES_ONLY=true

# Optional modality filters.
MODALITY_USE_NDVI=true
MODALITY_USE_NDSM=false

# Duplicate suppression.
# Local NMS operates on SAM masks inside one tile; global NMS operates on final
# georeferenced polygons across the whole job and suppresses duplicate artifacts.
LOCAL_MASK_NMS_IOU=0.6
LOCAL_MASK_CONTAINMENT_RATIO=0.9
GLOBAL_POLYGON_NMS_IOU=0.5
GLOBAL_POLYGON_CONTAINMENT_RATIO=0.85
GLOBAL_POLYGON_FRAGMENT_COVERAGE_RATIO=0.65
GLOBAL_POLYGON_FRAGMENT_MAX_AREA_RATIO=0.75
GLOBAL_POLYGON_FRAGMENT_BUFFER_M=1.0

# nDSM is derived locally as DOM - DGM. Both rasters are fetched from Bayern
# OpenData 1x1-km GeoTIFF tiles via polygon Metalink endpoints.
DGM_METALINK_URL=https://geoservices.bayern.de/services/poly2metalink/metalink/dgm1
DGM_TILE_CACHE_DIR=data/opendata/dgm1
DGM_NATIVE_STEP_M=1.0
DOM_METALINK_URL=https://geoservices.bayern.de/services/poly2metalink/metalink/dom20dom
DOM_TILE_CACHE_DIR=data/opendata/dom20
DOM_NATIVE_STEP_M=0.2
